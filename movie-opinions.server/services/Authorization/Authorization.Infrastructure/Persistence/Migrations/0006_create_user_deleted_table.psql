-- 1. Створення таблиці
CREATE TABLE IF NOT EXISTS user_deleted(
	id				UUID			NOT NULL,
	user_id			UUID			NOT NULL,
	login_user		VARCHAR(550)	NOT NULL,
	login_type		VARCHAR(250)	NOT NULL,
	country_code	VARCHAR(50)		NULL,
	reason			TEXT			NULL,
	deleted_at		TIMESTAMPTZ		NOT NULL,
	restore_until	TIMESTAMPTZ		NOT NULL,
	restore_at		TIMESTAMPTZ		NULL,
	status			TEXT			NOT NULL,
	update_at		TIMESTAMPTZ		NULL,
	created_at		TIMESTAMPTZ		NOT NULL,

	CONSTRAINT pk_user_deleted PRIMARY KEY (id),

	CONSTRAINT fk_user_deleted_user_id
	FOREIGN KEY (user_id)
	REFERENCES user_account(id)
	ON DELETE CASCADE
);

-- 2. Створення індексу для швидкого пошуку
CREATE INDEX IF NOT EXISTS idx_user_deleted_user_id
ON user_deleted (user_id);